<% content_for(:title) { "Documents - Draft Chamber" } %>

<h1 class="mb-6 text-2xl font-bold text-gray-900">Documents</h1>

<%= form_with url: documents_path, method: :get, class: "mb-4 flex items-center gap-2" do |f| %>
  <%= f.text_field :q, value: @query, placeholder: "Search by name...", class: "w-96 rounded-md border border-gray-300 px-3 py-2 text-md focus:border-ietf-accent focus:outline-none focus:ring-1 focus:ring-ietf-accent" %>
  <%= f.submit "Search", class: "rounded-md bg-ietf-blue px-4 py-2 text-md font-medium text-white hover:bg-ietf-dark cursor-pointer" %>
<% end %>

<div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-ietf-blue">
      <tr>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Name</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Title</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Type</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Rev</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Pages</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Group</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Material</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 bg-white">
      <% @documents.each do |document| %>
        <tr class="hover:bg-ietf-light">
          <td class="px-4 py-3 text-md"><%= link_to document.name, document_path(document), class: "font-medium text-ietf-accent hover:underline" %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= document.title %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= document.document_type %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= document.rev %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= document.pages %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= document.group&.acronym %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= document.material_attached? ? "Yes" : "No" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== @pagy.series_nav %>
</div>
