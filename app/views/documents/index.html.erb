<h1>Documents</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Title</th>
      <th>Type</th>
      <th>Rev</th>
      <th>Pages</th>
      <th>Group</th>
      <th>Material</th>
    </tr>
  </thead>
  <tbody>
    <% @documents.each do |document| %>
      <tr>
        <td><%= link_to document.name, document_path(document) %></td>
        <td><%= document.title %></td>
        <td><%= document.document_type %></td>
        <td><%= document.rev %></td>
        <td><%= document.pages %></td>
        <td><%= document.group&.acronym %></td>
        <td><%= document.material_attached? ? "Yes" : "No" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%== @pagy.series_nav %>
