<nav>
  <%= link_to "Meetings", meetings_path %> |
  <%= link_to "Groups", groups_path %> |
  <%= link_to "Sessions", sessions_path %> |
  <%= link_to "Documents", documents_path %> |
  <%= link_to "Session Presentations", session_presentations_path %>

  <% if current_user %>
    <span style="float: right;">
      <% if current_user.avatar_url.present? %>
        <%= image_tag current_user.avatar_url, size: "20x20" %>
      <% end %>
      <%= current_user.nickname %>
      <%= button_to "Logout", logout_path, method: :delete, data: { turbo: false } %>
    </span>
  <% end %>
</nav>
<hr>
