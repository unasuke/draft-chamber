<nav class="bg-ietf-blue">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <div class="flex items-center gap-6">
      <%= link_to "Meetings", meetings_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
      <%= link_to "Groups", groups_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
      <%= link_to "Sessions", sessions_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
      <%= link_to "Documents", documents_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
      <%= link_to "Session Presentations", session_presentations_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
      <% if current_user&.admin? %>
        <%= link_to "Admin", admin_root_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
      <% end %>
    </div>

    <% if current_user %>
      <div class="flex items-center gap-3">
        <% if current_user.avatar_url.present? %>
          <%= image_tag current_user.avatar_url, size: "24x24", class: "rounded-full" %>
        <% end %>
        <span class="text-md text-gray-200"><%= current_user.nickname %></span>
        <%= link_to "Authorized Apps", oauth_authorized_applications_path, class: "rounded bg-ietf-dark px-3 py-1 text-md text-gray-200 hover:bg-gray-700 hover:text-white" %>
        <%= button_to "Logout", logout_path, method: :delete, data: { turbo: false }, class: "rounded bg-ietf-dark px-3 py-1 text-md text-gray-200 hover:bg-gray-700 hover:text-white" %>
      </div>
    <% end %>
  </div>
</nav>
