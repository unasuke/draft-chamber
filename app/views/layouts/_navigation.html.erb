<nav class="bg-ietf-blue" data-controller="mobile-menu">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-3">
      <%# Desktop nav links (hidden on mobile, shown md+) %>
      <div class="hidden md:flex md:items-center md:gap-6">
        <%= link_to "Meetings", meetings_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
        <%= link_to "Groups", groups_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
        <%= link_to "Sessions", sessions_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
        <%= link_to "Documents", documents_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
        <%= link_to "Session Presentations", session_presentations_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
        <% if current_user&.admin? %>
          <%= link_to "Admin", admin_root_path, class: "text-md font-medium text-gray-200 hover:text-white" %>
        <% end %>
      </div>

      <%# Desktop user section (hidden on mobile, shown md+) %>
      <% if current_user %>
        <div class="hidden md:flex md:items-center md:gap-3">
          <% if current_user.avatar_url.present? %>
            <%= image_tag current_user.avatar_url, size: "24x24", class: "rounded-full" %>
          <% end %>
          <span class="text-md text-gray-200"><%= current_user.nickname %></span>
          <%= link_to "Authorized Apps", oauth_authorized_applications_path, class: "rounded bg-ietf-dark px-3 py-1 text-md text-gray-200 hover:bg-gray-700 hover:text-white" %>
          <%= button_to "Logout", logout_path, method: :delete, data: { turbo: false }, class: "rounded bg-ietf-dark px-3 py-1 text-md text-gray-200 hover:bg-gray-700 hover:text-white" %>
        </div>
      <% end %>

      <%# Hamburger button (shown on mobile, hidden md+) %>
      <button
        type="button"
        class="inline-flex items-center justify-center rounded p-2 text-gray-200 hover:bg-ietf-dark hover:text-white md:hidden"
        data-action="mobile-menu#toggle"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <svg data-mobile-menu-target="openIcon" class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg data-mobile-menu-target="closeIcon" class="hidden size-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%# Mobile menu panel (hidden by default, toggled by Stimulus) %>
    <div data-mobile-menu-target="menu" class="hidden border-t border-ietf-dark pb-3 md:hidden">
      <div class="flex flex-col gap-1 pt-2">
        <%= link_to "Meetings", meetings_path, class: "block rounded px-3 py-2 text-md font-medium text-gray-200 hover:bg-ietf-dark hover:text-white" %>
        <%= link_to "Groups", groups_path, class: "block rounded px-3 py-2 text-md font-medium text-gray-200 hover:bg-ietf-dark hover:text-white" %>
        <%= link_to "Sessions", sessions_path, class: "block rounded px-3 py-2 text-md font-medium text-gray-200 hover:bg-ietf-dark hover:text-white" %>
        <%= link_to "Documents", documents_path, class: "block rounded px-3 py-2 text-md font-medium text-gray-200 hover:bg-ietf-dark hover:text-white" %>
        <%= link_to "Session Presentations", session_presentations_path, class: "block rounded px-3 py-2 text-md font-medium text-gray-200 hover:bg-ietf-dark hover:text-white" %>
        <% if current_user&.admin? %>
          <%= link_to "Admin", admin_root_path, class: "block rounded px-3 py-2 text-md font-medium text-gray-200 hover:bg-ietf-dark hover:text-white" %>
        <% end %>
      </div>

      <% if current_user %>
        <div class="mt-3 border-t border-ietf-dark pt-3">
          <div class="flex items-center gap-3 px-3">
            <% if current_user.avatar_url.present? %>
              <%= image_tag current_user.avatar_url, size: "24x24", class: "rounded-full" %>
            <% end %>
            <span class="text-md text-gray-200"><%= current_user.nickname %></span>
          </div>
          <div class="mt-2 flex flex-col gap-1">
            <%= link_to "Authorized Apps", oauth_authorized_applications_path, class: "block rounded px-3 py-2 text-md text-gray-200 hover:bg-ietf-dark hover:text-white" %>
            <%= button_to "Logout", logout_path, method: :delete, data: { turbo: false }, class: "w-full rounded px-3 py-2 text-left text-md text-gray-200 hover:bg-ietf-dark hover:text-white" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</nav>
