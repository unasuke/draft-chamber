<% content_for(:title) { "Stale Reports - Draft Chamber" } %>

<h1 class="mb-6 text-2xl font-bold text-gray-900">Stale Reports</h1>

<% if @stale_reports.any? %>
  <div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-ietf-blue">
        <tr>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Resource</th>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Type</th>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Reporter</th>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Message</th>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Status</th>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Reported At</th>
          <th class="px-4 py-3 text-left text-md font-semibold text-white">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 bg-white">
        <% @stale_reports.each do |report| %>
          <tr class="hover:bg-ietf-light">
            <td class="px-4 py-3 text-md text-gray-600"><%= report.reportable.to_s %></td>
            <td class="px-4 py-3 text-md text-gray-600"><%= report.reportable_type %></td>
            <td class="px-4 py-3 text-md text-gray-600"><%= report.user.nickname %></td>
            <td class="px-4 py-3 text-md text-gray-600"><%= report.message.presence || "-" %></td>
            <td class="px-4 py-3 text-md text-gray-600"><%= report.status %></td>
            <td class="px-4 py-3 text-md text-gray-600"><%= report.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="px-4 py-3 text-md">
              <% if report.pending? %>
                <%= button_to "Acknowledge", acknowledge_admin_stale_report_path(report), method: :patch, class: "rounded bg-ietf-accent px-3 py-1 text-md font-medium text-white shadow-sm hover:bg-ietf-blue" %>
              <% elsif report.acknowledged? %>
                <%= button_to "Resolve", resolve_admin_stale_report_path(report), method: :patch, class: "rounded bg-green-600 px-3 py-1 text-md font-medium text-white shadow-sm hover:bg-green-700" %>
              <% else %>
                <span class="text-md text-gray-400">Resolved</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="mt-4">
    <%== @pagy.series_nav %>
  </div>
<% else %>
  <p class="text-md text-gray-500">No stale reports.</p>
<% end %>

<p class="mt-4">
  <%= link_to "Back to Admin Dashboard", admin_root_path, class: "text-md text-ietf-accent hover:underline" %>
</p>
