<div class="mt-6 rounded-lg border border-gray-200 bg-white p-4 shadow-sm">
  <details>
    <summary class="cursor-pointer text-md font-medium text-gray-700 hover:text-ietf-accent">
      Report stale data
    </summary>
    <div class="mt-3">
      <%= form_with url: url, scope: :stale_report, class: "space-y-3" do |f| %>
        <div>
          <%= f.label :message, "What seems outdated? (optional)", class: "block text-md font-medium text-gray-700" %>
          <%= f.text_area :message, rows: 2, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-md text-gray-900 placeholder-gray-400 shadow-sm focus:border-ietf-accent focus:outline-none focus:ring-1 focus:ring-ietf-accent" %>
        </div>
        <%= f.submit "Report", class: "cursor-pointer rounded bg-ietf-accent px-4 py-2 text-md font-medium text-white shadow-sm hover:bg-ietf-blue" %>
      <% end %>
    </div>
  </details>
</div>
