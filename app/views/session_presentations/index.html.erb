<h1 class="mb-6 text-2xl font-bold text-gray-900">Session Presentations</h1>

<div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-ietf-blue">
      <tr>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Order</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Session</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Meeting</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Document</th>
        <th class="px-4 py-3 text-left text-md font-semibold text-white">Rev</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 bg-white">
      <% @session_presentations.each do |sp| %>
        <tr class="hover:bg-ietf-light">
          <td class="px-4 py-3 text-md text-gray-600"><%= sp.order %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= sp.session.name %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= sp.session.meeting.number %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= sp.document.name %></td>
          <td class="px-4 py-3 text-md text-gray-600"><%= sp.rev %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== @pagy.series_nav %>
</div>
