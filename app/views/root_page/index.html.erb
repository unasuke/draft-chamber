<% content_for(:title) { "Draft Chamber - MCP Server for IETF Meeting Materials" } %>

<div class="bg-ietf-blue">
  <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24 lg:px-8">
    <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
      Draft Chamber
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-200">
      An MCP (Model Context Protocol) server for IETF meeting materials.
      Connect your AI assistant to explore meetings, sessions, documents, and presentations
      from the IETF Datatracker.
    </p>
  </div>
</div>

<div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
  <% if current_user %>
    <div class="rounded-lg border border-gray-200 bg-white p-8 shadow-sm">
      <h2 class="mb-4 text-xl font-bold text-gray-900">MCP Server Setup</h2>
      <p class="mb-6 text-md text-gray-600">
        Connect your MCP-compatible client to Draft Chamber using the endpoint below.
        OAuth 2.1 with PKCE is required for authentication.
      </p>

      <div class="mb-6 rounded-md bg-gray-50 p-4">
        <p class="mb-1 text-md font-medium text-gray-700">MCP Endpoint</p>
        <code class="text-md font-mono text-ietf-accent"><%= request.base_url %>/mcp</code>
      </div>

      <p class="mb-6 text-md text-gray-600">
        Your client will automatically discover the OAuth configuration via the
        <code class="rounded bg-gray-100 px-1 py-0.5 text-md font-mono">/.well-known/oauth-protected-resource</code>
        endpoint.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to "Browse Meetings", meetings_path, class: "rounded bg-ietf-accent px-4 py-2 text-md font-medium text-white shadow-sm hover:bg-ietf-blue" %>
        <%= link_to "Authorized Apps", oauth_authorized_applications_path, class: "rounded border border-gray-300 bg-white px-4 py-2 text-md font-medium text-gray-700 shadow-sm hover:bg-gray-50" %>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border border-gray-200 bg-white p-8 shadow-sm text-center">
      <h2 class="mb-4 text-xl font-bold text-gray-900">Get Started</h2>
      <p class="mb-6 text-md text-gray-600">
        Sign in with GitHub to access meeting data and configure your MCP client.
      </p>
      <%= button_to "Sign in with GitHub", "/auth/github", data: { turbo: false }, class: "rounded bg-gray-900 px-6 py-3 text-md font-medium text-white shadow-sm hover:bg-gray-700 cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="mb-2 text-lg font-semibold text-gray-900">Meetings</h3>
      <p class="text-md text-gray-600">Browse IETF meeting data including dates, venues, and attendance.</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="mb-2 text-lg font-semibold text-gray-900">Sessions & Documents</h3>
      <p class="text-md text-gray-600">Access working group sessions and associated presentation materials.</p>
    </div>
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="mb-2 text-lg font-semibold text-gray-900">MCP Protocol</h3>
      <p class="text-md text-gray-600">Integrate with any MCP-compatible AI assistant via OAuth 2.1 with PKCE.</p>
    </div>
  </div>
</div>
